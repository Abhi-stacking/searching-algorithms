#include <iostream>
using namespace std;
bool linear(int arr[], int size, int key){
    for(int i=0;i<size;i++){
        if(arr[i]==key) return true;
    } return false;
}

int main(){
int arr[] = {1, 2, 7, -4, 5};
int key;
cout<<"enter key: "<< endl;
cin>>key;
bool search = linear(arr, 5, key);
if(search == true){
    cout<<"present";
}else cout<<"absent";

    return 0;
    
}

