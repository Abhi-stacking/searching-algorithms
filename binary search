#include <iostream>
using namespace std;

int binarySearch(int arr[], int size, int key){
    int start = 0;
    int end = size - 1;
    int mid = (start+end)/2;
    
    while(start<=end){
        if(arr[mid]==key){
            return mid;
        }
        if(arr[mid]>key){
            end = mid-1;
        }
        if(arr[mid]<key){
            start = mid+1;
        }
        mid = (start+end)/2;
        
    }return -1;
}

int main() {
int even[6] = {2,3,5,6,8,12};
int odd[5] = {1,4,6,12,37};
int Index = binarySearch(even, 6, 8);
cout << "index of 8 is: " << Index << endl;
Index = binarySearch(odd, 5, 37);
cout << "index of 37 is: " << Index << endl;
Index = binarySearch(odd, 5, 40);
cout << "index of 40 is: " << Index << endl;
}
